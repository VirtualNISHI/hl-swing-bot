# Copy to .env and fill in.
# .env is gitignored — never commit it.

# Discord webhook for notifications.
# Get from your Discord channel → Edit Channel → Integrations → Webhooks.
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Hyperliquid wallet (Phase 0 doesn't need this — only for execution in Phase 3+).
# Use a SEPARATE API wallet, not your main wallet. Never expose your main private key.
# HL_API_WALLET_ADDRESS=0x...
# HL_API_WALLET_PRIVATE_KEY=0x...

# Data directory (DuckDB file lives here).
DATA_DIR=./data

# Collector settings.
HL_COIN=BTC
HL_CANDLE_INTERVAL=1m
HL_LOOKBACK_MINUTES=120
